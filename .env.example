# ==================== CONFIGURACIÓN LOCAL ====================
# Este archivo muestra qué variables de entorno necesita tu app
# Para desarrollo local, copia esto a .env
# Para producción en Render, copia estos valores a Environment Variables

# ==== DJANGO BASICS ====
DEBUG=True
SECRET_KEY=your-secret-key-here

# ==== DATABASE (LOCAL) ====
# Para desarrollo local con MariaDB
DB_ENGINE=django.db.backends.mysql
DB_NAME=proyecto
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ==== ALLOWED HOSTS ====
ALLOWED_HOSTS=localhost,127.0.0.1

# ==== SMTP GMAIL ====
# Obtener App Password en: https://myaccount.google.com/apppasswords
# NO uses tu contraseña normal de Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password-aqui
DEFAULT_FROM_EMAIL=Tu Nombre <tu-email@gmail.com>

# ==== SECURITY (SOLO PARA PRODUCCIÓN) ====
# Descomenta estas líneas solo si DEBUG=False
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
